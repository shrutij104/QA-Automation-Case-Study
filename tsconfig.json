{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "types": [
      "node",
      "@playwright/test"
    ],

    "skipLibCheck": true
  },

  "include": [
    "tests",
    "pages",
    "api",
    "config",
    "utils",
    "playwright.config.ts"
  ]
}